# Upkeep Status configuration — copy to .env and edit

# Port the web app listens on
PORT=5342

# Admin password for /admin (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location
DB_PATH=./data/upkeep.db

# Site branding shown on the public page
SITE_NAME=Upkeep Status

# Public base URL of this install — used in subscriber emails + RSS links
# e.g. https://status.yourdomain.com  (reverse-proxy friendly: any domain works)
BASE_URL=

# SMTP for subscriber notifications (optional — page works without)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
